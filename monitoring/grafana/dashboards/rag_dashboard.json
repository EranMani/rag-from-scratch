{
  "title": "Educational RAG System",
  "uid": "rag-dashboard",
  "panels": [
    {
      "title": "Request Latency p95 (seconds)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(rag_request_latency_seconds_bucket[5m]))",
        "legendFormat": "p95"
      }]
    },
    {
      "title": "Cache Hit Rate",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(rate(rag_cache_hits_total[5m])) / (sum(rate(rag_cache_hits_total[5m])) + sum(rate(rag_cache_misses_total[5m])))",
        "legendFormat": "hit rate"
      }]
    },
    {
      "title": "LLM Calls by Provider",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 6 },
      "targets": [{
        "expr": "rate(rag_llm_calls_total[5m])",
        "legendFormat": "{{provider}} {{status}}"
      }]
    },
    {
      "title": "Circuit Breaker States",
      "type": "table",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 4 },
      "targets": [{
        "expr": "rag_circuit_breaker_state",
        "legendFormat": "{{service}}"
      }]
    }
  ],
  "schemaVersion": 38,
  "version": 1
}
