# Production environment variables — copy to .env.prod and fill in real values.
# No secret has a default. Startup will fail loudly if any required value is missing.

# ---------------------------------------------------------------------------
# SECRETS — required, no defaults, never commit real values
# ---------------------------------------------------------------------------

# OpenAI API key (required when LLM_PROVIDER=openai)
# Obtain from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# JWT signing secret — minimum 32 characters, startup fails if shorter.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# NiceGUI session-storage cookie signing secret — minimum 32 characters.
# Must differ from JWT_SECRET. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
NICEGUI_STORAGE_SECRET=

# Grafana admin password — set before first boot; cannot be changed via UI after init.
GRAFANA_ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# LLM PROVIDER
# ---------------------------------------------------------------------------

# "openai" or "ollama"
LLM_PROVIDER=openai

OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Used when LLM_PROVIDER=ollama (service is always started; pull model after first boot)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=gemma3:4b

# ---------------------------------------------------------------------------
# EMBEDDING
# ---------------------------------------------------------------------------

# "openai" or "local"
EMBEDDING_PROVIDER=local

# ---------------------------------------------------------------------------
# DATA LAYER
# ---------------------------------------------------------------------------

CHROMA_HOST=chroma
# Container-internal port — chroma listens on 8000 inside the network; host mapping is 8001:8000 for dev tooling only
CHROMA_PORT=8000
CHROMA_COLLECTION=rag_knowledge_base

REDIS_URL=redis://redis:6379/0
CACHE_TTL_QUERY=3600
CACHE_TTL_EMBEDDING=86400
CACHE_TTL_LLM=1800

# ---------------------------------------------------------------------------
# CIRCUIT BREAKER
# ---------------------------------------------------------------------------

CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT=30

# ---------------------------------------------------------------------------
# APPLICATION
# ---------------------------------------------------------------------------

APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

PROMETHEUS_PORT=9090

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
SQLITE_DB_PATH=data/app_users.db

# Set true to allow /api/chat without Authorization header
ALLOW_ANONYMOUS_CHAT=false
