# LLM Provider: "openai" or "ollama"
LLM_PROVIDER=openai

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Ollama (used when LLM_PROVIDER=ollama or as fallback)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=gemma3:4b

# Embedding backend: "openai" or "local"
EMBEDDING_PROVIDER=local

# ChromaDB
CHROMA_HOST=chroma
CHROMA_PORT=8001
CHROMA_COLLECTION=rag_knowledge_base

# Redis
REDIS_URL=redis://redis:6379/0
CACHE_TTL_QUERY=3600        # 1 hour — exact question → answer
CACHE_TTL_EMBEDDING=86400   # 24 hours — text → vector
CACHE_TTL_LLM=1800          # 30 minutes — prompt hash → response

# Circuit breaker thresholds
CB_FAILURE_THRESHOLD=5      # failures before OPEN
CB_RECOVERY_TIMEOUT=30      # seconds before HALF-OPEN probe

# App
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Monitoring
PROMETHEUS_PORT=8001