# Required for the demo and OpenAI-backed app paths.
# Replace this first for the OpenAI path.
# If this is empty, demo.py falls back to Ollama generation and local embeddings.
OPENAI_API_KEY=your_openai_api_key_here

# Chat model used for answer generation.
OPENAI_MODEL=gpt-4o-mini

# Embedding model used to build the Chroma vector index.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional aliases used by the standalone demo script's OpenAI path.
# Leave these aligned with the OpenAI settings above unless you want the demo
# to use different models than the web app.
MODEL_NAME=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Force the standalone demo to use Ollama even when OPENAI_API_KEY is set.
# Useful when you want to show the fallback path intentionally.
DEMO_FORCE_OLLAMA=false

# LLM provider for the full app: openai or ollama.
LLM_PROVIDER=openai

# Embedding backend for the full app: openai or local.
EMBEDDING_PROVIDER=openai

# Ollama fallback/local model settings.
# For local demo fallback:
#   1. Install and start Ollama: https://ollama.com
#   2. Pull the model: ollama pull gemma3:4b
#   3. Leave OPENAI_API_KEY empty or set DEMO_FORCE_OLLAMA=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# ChromaDB connection for the full Docker/app stack.
# The standalone demo creates its own local Chroma index under data/demo_chroma_db/.
CHROMA_HOST=chroma
CHROMA_PORT=8001
CHROMA_COLLECTION=rag_knowledge_base

# Redis cache connection for the full app.
REDIS_URL=redis://redis:6379/0

# Cache TTLs in seconds.
CACHE_TTL_QUERY=3600
CACHE_TTL_EMBEDDING=86400
CACHE_TTL_LLM=1800

# Circuit breaker settings for external dependencies.
CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT=30

# FastAPI host/port and log verbosity.
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Prometheus metrics port.
PROMETHEUS_PORT=9090

# JWT signing secret for authenticated app routes.
# Must be at least 32 characters.
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# SQLite database path for local app users and profiles.
SQLITE_DB_PATH=data/app_users.db

# Set true to allow /api/chat without Authorization.
ALLOW_ANONYMOUS_CHAT=false

# NiceGUI session-storage cookie signing secret.
# Must be at least 32 characters.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
NICEGUI_STORAGE_SECRET=change-me-to-a-long-random-string-at-least-32-chars
